# App
NEXT_PUBLIC_APP_URL=http://localhost:3200
NEXT_PUBLIC_BASE_PATH=
AUTH_SECRET=replace-with-a-long-random-secret

# Database
POSTGRES_URL=postgres://postgres:postgres@localhost:5432/lingjing

# Optional rate limit storage for production
REDIS_URL=

# Local Ollama models
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_API_KEY=ollama

# Alibaba DashScope
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Optional aliases supported by the provider layer
ALIBABA_API_KEY=
QWEN_API_KEY=
OPENAI_API_KEY=

# Optional Vercel AI Gateway
AI_GATEWAY_API_KEY=

# Optional demo flag
IS_DEMO=0

# Optional Vercel Blob token. If omitted, uploads fall back to local public/uploads.
BLOB_READ_WRITE_TOKEN=
