# 应用基础配置
NEXT_PUBLIC_APP_URL=http://localhost:3200
NEXT_PUBLIC_BASE_PATH=
AUTH_SECRET=replace-with-a-long-random-secret

# 数据库
POSTGRES_URL=postgres://postgres:postgres@localhost:5432/lingjing

# 可选：生产环境限流
REDIS_URL=

# 本地 Ollama 模型
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_API_KEY=ollama

# 阿里云 DashScope
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 可选别名，provider 层兼容这些变量名
ALIBABA_API_KEY=
QWEN_API_KEY=
OPENAI_API_KEY=

# 可选：Vercel AI Gateway
AI_GATEWAY_API_KEY=

# 可选：演示模式
IS_DEMO=0

# 可选：Vercel Blob。未配置时，上传会自动回退到 public/uploads
BLOB_READ_WRITE_TOKEN=
